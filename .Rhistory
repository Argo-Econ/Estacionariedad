# carga de librerias
require(pacman) # library(pacman)
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS)
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS)
# Importacion datos ----
#------------------------------------------------------------------------------#
Datos_ent <- read_xlsx(path = "BD.xlsx"
,sheet = "BD",range = "a1:b256"
,col_names = T)
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS, xts)
bd_xts <- Datos_ent$Comercio %>% xts(order.by = as.Date(Datos_ent$Fecha))
ts_plot(bd_xts)
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS, xts, stats)
bd_ts  <- ts(Datos_ent$Comercio, start = (2005,1), frequency=12)
ts(Datos_ent$Comercio, start = (2005,1), frequency=12)
bd_ts  <- ts(Datos_ent$Comercio, start = c(2005,1), frequency=12)
bd_ts
adf.test(x = bd_ts,alternative = "stationary")
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS, xts, stats, tseries)
adf.test(x = bd_ts,alternative = "stationary")
Datos_ent
View(Datos_ent)
# Prueba separada ---------------------------------------------------------
# ADF con tendencia
adf_trend <- ur.df(bd_ts, type = "trend", lags = 6)
pacman::p_load(readxl, TSA, tsoutliers, TSstudio, dplyr
, MASS, nortest, FinTS, xts, stats, tseries, urca)
# Prueba separada ---------------------------------------------------------
# ADF con tendencia
adf_trend <- ur.df(bd_ts, type = "trend", lags = 6)
summary(adf_trend)
windows()
plot(bd_ts)
adf_trend <- ur.df(bd_ts, type = "trend", lags = 6)
summary(adf_trend)
# Prueba separada ---------------------------------------------------------
# ADF con tendencia
adf_trend <- ur.df(bd_ts, type = "trend", selectlags = c("AIC"))
summary(adf_trend)
# ADF con solo constante
adf_drift <- ur.df(bd_ts, type = "drift", selectlags = c("AIC"))
summary(adf_drift)
# ADF con solo constante
adf_drift <- ur.df(bd_ts, type = "drift", selectlags = c("AIC"))
summary(adf_drift)
# ADF sin constante ni tendencia
# Δz_t = alpha + gamma z_t-1+ delta_1 Δz_t-1 + u_t
adf_none <- ur.df(bd_ts, type = "none", lags = 6)
summary(adf_none)
# Pruebas complementaria --------------------------------------------------
kpss.test(bd_ts) # H0: serie estacionaria
# Pruebas complementaria --------------------------------------------------
kpss.test(bd_ts, null = "Trend") # H0: serie estacionaria
# Pruebas complementaria --------------------------------------------------
kpss.test(bd_ts, null = "Trend") # H0: serie estacionaria alrededor de una tendencia
kpss.test(bd_ts, null = "Level") # H0: serie estacionaria alrededor de una constante
pp.test(bd_ts)   # H0: serie no estacionaria
pp.test(bd_ts,type = "Z(t_alpha)")   # H0: serie no estacionaria
pp.test(bd_ts,type = "Z(alpha)")   # H0: serie no estacionaria alrededor de una tendencia deterministica
# Test de raiz unitaria de Phillips–Perron
pp.test(bd_ts,type = "Z(t_alpha)")   # H0: serie no estacionaria alrededor de una tendencia deterministica
pp.test(bd_ts,type = "Z(alpha)")   # H0: serie no estacionaria alrededor de una tendencia deterministica
